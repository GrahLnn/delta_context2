TASK_MODEL="gpt-4o-mini"
TRANSLATION_MODEL="gpt-4o-mini"

OPENAI_API_KEY="sk-n" # replace with your openai api key
OPENAI_API_URL="https://api.openai.com/v1" # replace with yours
OPENAI_TIMEOUT="300"

# Mega-ASR weights are downloaded to this directory on first use if missing.
MEGA_ASR_CKPT_DIR="ckpt/Mega-ASR"
MEGA_ASR_ROUTING_ENABLED="true"
MEGA_ASR_ROUTER_WINDOW_SECONDS="30"
MEGA_ASR_ROUTER_MAX_WINDOWS="12"
MEGA_ASR_ROUTER_DEGRADED_RATIO="0.5"
MEGA_ASR_MAX_NEW_TOKENS="2048"
MEGA_ASR_BATCH_SIZE="16"

ASS_STYLE=""  # Format: Name,Fontname,Fontsize,PrimaryColour,SecondaryColour,TertiaryColour,BackColour,Bold,Italic,Underline,StrikeOut,ScaleX,ScaleY,Spacing,Angle,BorderStyle,Outline,Shadow,Alignment,MarginL,MarginR,MarginV,AlphaLevel,Encoding
